# Copy this file to `.env` and fill in your token. `.env` is gitignored — never
# commit it. Create a token (a "read" token is enough for downloading the model)
# at https://huggingface.co/settings/tokens
#
# Load it into a command with uv:   uv run --env-file .env pytest -m model
# or make it the default this shell: export UV_ENV_FILE=.env
HF_TOKEN=hf_your_token_here
