{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write|NotebookEdit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/_run.sh\" \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/guard_paths.py\"",
            "statusMessage": "Checking protected paths…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/_run.sh\" \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/check_torch_free.py\"",
            "statusMessage": "Checking torch-free boundary…"
          }
        ]
      }
    ]
  }
}
